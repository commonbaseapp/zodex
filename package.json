{
  "name": "zodex",
  "version": "0.0.0-dev",
  "description": "Type-safe (de)serialization for Zod",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    },
    "./src/schema.zodex": "./src/schema.zodex"
  },
  "keywords": [
    "zod",
    "serialization",
    "deserialization",
    "reflection"
  ],
  "author": "Gregor Weber<mail@dflate.io>",
  "license": "MIT",
  "scripts": {
    "start": "static",
    "prepare": "husky",
    "check-style": "prettier --check src",
    "lint": "eslint --no-warn-ignored .",
    "test": "vitest --coverage --silent=false --reporter=basic",
    "build:demo": "rollup -c",
    "build": "rm -rf dist && pnpm tsc --module esnext --moduleResolution bundler --outDir dist/esm && pnpm tsc && echo '{\"type\": \"commonjs\"}' > dist/package.json && echo '{\"type\": \"module\"}' > dist/esm/package.json",
    "prepublish": "pnpm run build"
  },
  "peerDependencies": {
    "@types/react": "^18.x",
    "react": "^18.x",
    "zod": "^3.x"
  },
  "dependencies": {
    "@brettz9/jsonref": "^0.1.0",
    "react": "^18.3.1",
    "type-fest": "^4.20.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@brettz9/node-static": "^0.1.1",
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "@types/react": "18.3.3",
    "@vitest/coverage-v8": "^1.6.0",
    "esbuild": "0.21.5",
    "eslint": "9.5.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "^15.6.0",
    "husky": "9.0.11",
    "lint-staged": "15.2.7",
    "prettier": "3.3.2",
    "rollup": "^4.18.0",
    "typescript": "5.5.x",
    "typescript-eslint": "8.0.0-alpha.34",
    "vitest": "1.6.0"
  },
  "packageManager": "pnpm@9.1.4",
  "files": [
    "dist/*"
  ],
  "lint-staged": {
    "*.ts": "eslint --cache --fix src/**",
    "*.{ts,js,json,md}": "prettier --write"
  }
}
